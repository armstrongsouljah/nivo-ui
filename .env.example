# Copy to .env and fill in. Used both for `npm run dev` and by
# `docker compose up` (docker-compose.yml reads this file automatically).

# Reachable from the browser, not just the server — this is inlined into
# the JS bundle at build time. If running nivo-api's own docker-compose
# stack alongside this one, its API is published at localhost:8082.
#
# Note for `docker compose up` specifically: this container can't reach
# "localhost:8082" on the host (that's its own loopback). Use
# http://host.docker.internal:8082/api/v1/ instead when testing this way
# on Docker Desktop — server-side fetches will work, though the browser
# still needs its own reachable URL, so pick whichever your setup needs.
# In a real deployment NEXT_PUBLIC_API_URL is a public hostname reachable
# from both, so this only matters for local docker-compose testing.
NEXT_PUBLIC_API_URL=http://localhost:8082/api/v1/

# cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
