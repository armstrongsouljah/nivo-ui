# Copy to .env and fill in. Used both for `npm run dev` and by
# `docker compose up` (docker-compose.yml reads this file automatically).

# Reachable from the browser — this is inlined into the JS bundle at build
# time (frozen after `docker compose build`, changing it needs a rebuild).
# If running nivo-api's own docker-compose stack alongside this one, its
# API is published at localhost:8082.
NEXT_PUBLIC_API_URL=http://localhost:8082/api/v1/

# Optional: overrides where THIS server issues its own fetches (SSR, server
# actions), read live at container start — no rebuild needed. Only set this
# for local `docker compose up` testing, where "localhost:8082" from inside
# the container refers to itself, not the host running nivo-api. Leave
# unset in real deployments, where NEXT_PUBLIC_API_URL is already reachable
# from both the browser and the server.
# SERVER_API_URL=http://host.docker.internal:8082/api/v1/

# cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
